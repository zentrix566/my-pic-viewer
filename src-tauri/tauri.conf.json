{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "my-pic-viewer",
  "version": "0.1.0",
  "identifier": "com.zentrix566.mypicviewer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "my-pic-viewer",
        "width": 1200,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["SimpChinese", "English"]
      }
    },
    "fileAssociations": [
      {
        "ext": ["jpg", "jpeg", "png", "gif", "bmp", "webp", "ico", "tif", "tiff"],
        "name": "Image",
        "description": "图片文件",
        "role": "Viewer"
      }
    ]
  }
}
